// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// Models 

// Product Model
model Product {
  id        Int @id @default(autoincrement())
  name      String
  SKU       String @unique
  desc      String?
  images    String[]
  category  String?
  listings  Listing[]
  orders    Order[]
}

//Listing Model
model Listing {                                                        
  id         Int     @id @default(autoincrement())                     
  platform   String  // "ebay", "etsy", "amazon"                       
  platformId String  // the listing ID on that platform                
  url        String?                                                   
  price      Float                                                   
  quantity   Int     // stock on this platform
  status     String  // "active", "sold", "inactive"
  productId  Int
  product    Product @relation(fields: [productId], references: [id])
}

// Order Model
model Order {
  id        Int      @id @default(autoincrement())
  platform  String   // "ebay", "etsy", "amazon"
  orderId   String   @unique // platform's order ID
  quantity  Int
  salePrice Float
  date      DateTime @default(now())
  status    String   // "pending", "shipped", "delivered"
  productId Int
  product   Product @relation(fields: [productId], references: [id])
}
